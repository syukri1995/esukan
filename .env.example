# =============================================
# E-Sukan — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =============================================
#
# Local Jetty (H2 in-memory by default in esukan.properties):
#   mvn jetty:run
#   Open: http://localhost:9090/login.html
#
# Docker Compose (MySQL + Tomcat): docker compose up -d --build
#

# --- TiDB Cloud (local Jetty: mvn jetty:run or .\scripts\run-jetty-tidb.ps1) ---
# From TiDB Cloud console: Connect → General → copy host, port (4000), user, password, database.
# Use the JDBC URL TiDB shows, or build:
#   jdbc:mysql://<host>:4000/<database>?sslMode=VERIFY_IDENTITY&enabledTLSProtocols=TLSv1.2,TLSv1.3
ESUKAN_DB_USE_H2=false
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Docker Compose MySQL (not used when ESUKAN_DB_USE_H2=false and SPRING_DATASOURCE_* are set)
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USER=esukan_user
MYSQL_PASSWORD=change_this_strong_password

# Domain (used by nginx + certbot)
DOMAIN=yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com

# Auth / JWT (override in production)
# ESUKAN_JWT_SECRET=use-openssl-rand-hex-32-or-longer
# ESUKAN_JWT_EXPIRATION_MS=86400000
# ESUKAN_CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:8080

# --- Production smoke (scripts/smoke-prod.ps1) ---
SMOKE_RENDER_URL=https://esukan-api.onrender.com
SMOKE_VERCEL_URL=https://esukan-six.vercel.app
# SMOKE_STUDENT_USER=smoke_student
# SMOKE_STUDENT_PASSWORD=smoke123
# SMOKE_ADMIN_USER=smoke_admin
# SMOKE_ADMIN_PASSWORD=smoke123

# Optional SMTP for password-reset emails (not wired in servlet build yet)
# ESUKAN_MAIL_HOST=smtp.example.com
# ESUKAN_MAIL_USERNAME=
# ESUKAN_MAIL_PASSWORD=
# ESUKAN_MAIL_FROM=noreply@example.com
