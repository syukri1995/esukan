# Copy values into Render dashboard → esukan-api → Environment (after Blueprint deploy).
# Do NOT commit real passwords.

ESUKAN_DB_USE_H2=false
SPRING_DATASOURCE_URL=jdbc:mysql://gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/esukan_db?sslMode=VERIFY_IDENTITY&enabledTLSProtocols=TLSv1.2,TLSv1.3
SPRING_DATASOURCE_USERNAME=your-tidb-user
SPRING_DATASOURCE_PASSWORD=your-tidb-password
ESUKAN_JWT_SECRET=generate-a-long-random-secret-at-least-32-chars
